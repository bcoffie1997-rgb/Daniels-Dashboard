# ============================================================================
# MISE — Environment variables template
# Copy this file to .env.local in the project root and fill in real values.
# Never commit .env.local to git.
# ============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Mise

# --- Supabase ---
# Project URL: https://supabase.com/dashboard/project/<PROJECT_REF>
# Get keys from: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only, NEVER expose to client

# --- Resend (transactional email + Supabase SMTP) ---
# Sign up: https://resend.com — verify your sending domain first
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@<your-domain>

# --- PostHog ---
# Get from: https://posthog.com → project settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Sentry ---
# Get from: https://sentry.io → project settings
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                  # for source map uploads on deploy
SENTRY_ORG=
SENTRY_PROJECT=

# --- Feature flags ---
NEXT_PUBLIC_ENABLE_REALTIME=true    # Supabase realtime for manager dashboard
NEXT_PUBLIC_USE_MOCK_DATA=false       # true = demo role picker, false = magic-link auth
